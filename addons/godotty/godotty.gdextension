[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
linux.debug.x86_64 = "bin/libgodotty.linux.x86_64.so"
linux.release.x86_64 = "bin/libgodotty.linux.x86_64.so"
macos.debug = "bin/libgodotty.macos.dylib"
macos.release = "bin/libgodotty.macos.dylib"
windows.debug.x86_64 = "bin/libgodotty.windows.x86_64.dll"
windows.release.x86_64 = "bin/libgodotty.windows.x86_64.dll"
